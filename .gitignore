# =============================================
# Godot-specific ignores (from github/gitignore + community best practices 2026)
# =============================================

# Godot 4+ editor folder (local cache, workspace, etc.)
.godot/

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg
export_credentials.cfg           # contains sensitive keys/tokens
*.import                         # ← DO commit these! (critical for assets)
*.uid                            # ← DO commit these! (critical for assets)
*.translation                    # auto-generated from CSV

# Mono-specific ignores (if/when using C# later)
.mono/
data_*/
mono_crash.*.json

# Temporary files
*.tmp
*.import.tmp

# =============================================
# Python virtual environments & caches (your section - kept)
# =============================================
**/.venv/
**/.venv*/
venv/
env/
__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]
pyvenv.cfg
.python-version
Pipfile.lock
poetry.lock

# =============================================
# IDE / editor / temporary files
# =============================================
.vscode/
.idea/
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db
*.code-workspace

# =============================================
# Logs, backups, temporary & debug files
# =============================================
**/logs/
**/log/
log/
logs/
backup/
archive/
*.log
*.log.*
*.log.txt
*.bak
*.bak*
*.tmp
*.temp
notes/

# =============================================
# Generated / large / binary files (do NOT commit)
# =============================================
**/dbs/
**/data/
models.db
*.db
*.sqlite
*.sqlite3
*.duckdb
*.acdb
**/*.db
**/*.acdb

# Audio/ML tooling & models (your section - good)
ffmpeg/
demucs/
lib_v5/
_pretrained_models/
**/_pretrained_models/
*.dll                # ← careful: keep Godot/py4godot DLLs if needed; ignore extras
*.exe
*.so
*.dylib
*.onnx
*.pt
*.pth
*.safetensors
*.ckpt*
*.data-*
*.index
*.meta

# Large audio datasets/samples
songs/
samples/
*.wav
*.flac
*.mp3

# Old legacy artifacts
**/*.au3.txt
**/*.au3.bak

# =============================================
# Project-specific extras (add as needed)
# =============================================
# Ignore full py4godot archive/extract during prototype
install_dir/
py4godot/                # ← or add sub-paths like py4godot/cpython-* except windows64 if integrating
**/cpython-*-darwin*     # multi-platform builds
**/cpython-*-linux*
**/cpython-*-arm*

# Builds / exports (when you start exporting)
builds/
export/
*.pck
*.zip